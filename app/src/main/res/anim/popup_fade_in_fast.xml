<?xml version="1.0" encoding="utf-8"?>
<!--
  FAST variant of popup_fade_in — the SEND sheet's window OPEN animation.
  Same gentle alpha fade + tiny scale-up as popup_fade_in, but ~120ms instead
  of 200ms so the window settles (and onEnterAnimationComplete fires) sooner,
  which makes the view-level slide-up start sooner, so the sheet animates in
  over the still-fading chooser instead of appearing already settled.

  WHY a separate resource (not just shortening popup_fade_in): popup_fade_in is
  shared by Theme.Bada.ReceiveSheet (the consent sheet) via the shared
  WindowAnimation.Bada.SendSheet style; this fast variant is wired ONLY to
  the SEND sheet (WindowAnimation.Bada.SendSheet.Fast) so the consent
  sheet's entrance is unchanged.

  Still a FADE only (no vertical translate): the visible slide-up is the
  DraggableSheetLayout.playEntrance VIEW animation, triggered AFTER this fade
  finishes (SendActivity.onEnterAnimationComplete) so it is not masked by the
  window transition. Keeping a short (not zero) fade preserves that ordering —
  a zero-duration window animation risks the OnePlus "appears already settled,
  no slide" masking bug that the onEnterAnimationComplete trigger fixed.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="120"
    android:interpolator="@android:interpolator/decelerate_quad">

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0" />

    <scale
        android:fromXScale="0.96"
        android:toXScale="1.0"
        android:fromYScale="0.96"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%" />

</set>
