<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for SendActivity (#24) — restructured for Phase 1 into an
  bottom sheet (see dev.bluehouse.bada.ui.sheet.DraggableSheetLayout).

  Shape (back to front):
    1. Root FrameLayout — transparent, match_parent, bottom gravity.
       Hosted by the translucent Theme.Bada.SendSheet so the
       app/launcher behind shows through a soft 0.2 dim. Tapping the
       empty scrim area (send_sheet_scrim) dismisses the activity.
    2. send_sheet — a bottom-anchored DraggableSheetLayout: a rounded
       ~28dp light surface, pinned to the bottom with side margins,
       that slides up on entrance and can be dragged down to dismiss.
       It hosts every piece of state the activity renders:
         * Header: the device-name pill (relocated here from the old
           toolbar) + the payload summary / size / subtitle.
         * Picker: a HORIZONTAL row of circular DeviceIconView icons
           (added at runtime to send_peer_list inside a horizontal
           scroller) + the empty-state line + the same-Wi-Fi hint card.
         * Status panel: connection phase, PIN, circular progress,
           success preview.
         * QR panel: the in-sheet QR-code handshake view.
         * Action row: Show QR icon, Cancel / Done, help link.

  Every @+id SendActivity.kt / SendPeerPickerController look up is
  preserved; only the view *layer* changed, not the controller logic.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/send_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--
      Full-bleed transparent scrim. Sits behind the sheet and consumes
      taps outside the card; SendActivity wires its click to finish()
      (slide-down dismiss). Drawn first so the sheet floats on top.
    -->
    <View
        android:id="@+id/send_sheet_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!--
      Bottom-anchored sheet card. The fixed 480dp content height of the
      old centered card is kept on the inner content frame so state-to-
      state geometry (picker / sending / QR / success) stays consistent
      and the QR scroll keeps working; the sheet itself wraps that plus
      its rounded-surface padding.
    -->
    <dev.bluehouse.bada.ui.sheet.DraggableSheetLayout
        android:id="@+id/send_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/send_sheet_background"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="8dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp">

        <!--
          send_sheet_content — wraps ALL of the sheet's content (the device
          pill + the 480dp state frame). The entrance "bounce" scales the whole
          sheet to stretch its rounded BACKGROUND, and this wrapper takes the
          exact inverse scale (same bottom pivot) so the content itself does NOT
          move — only the card surface stretches. Wired via
          DraggableSheetLayout.setBounceContent in SendActivity.wireBottomSheet.
        -->
        <LinearLayout
            android:id="@+id/send_sheet_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

        <!--
          Sheet header: the device-name pill (relocated from the old
          toolbar) centered at the top of the card so the user sees
          who the share is "from" at a glance. The id is preserved so
          binding.sendDevicePillText still resolves.
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/send_device_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/send_device_pill_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="Pixel 8" />

        </com.google.android.material.card.MaterialCardView>

        <!--
          Card content host. Layered, fixed 480dp tall so the popup
          never changes size between states. From back to front:
            1. dialog_gradient_background view — subtle sky-blue card tint.
            2. send_pin_state_background — PIN-pairing radial backdrop.
            3. send_card_blur / send_card_overlay — success backdrop.
            4. send_picker_content — picker + status panel.
            5. send_qr_scroll / send_qr_panel — in-sheet QR view.
            6. send_show_qr_button — floating QR icon.
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="480dp"
            android:clipChildren="true"
            android:clipToOutline="true">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/dialog_gradient_background" />

            <View
                android:id="@+id/send_pin_state_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/pin_state_background"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/send_card_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

            <View
                android:id="@+id/send_card_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/card_blur_overlay"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/send_picker_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/send_payload_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textStyle="bold"
                    tools:text="1 file" />

                <TextView
                    android:id="@+id/send_payload_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:textColor="?android:attr/textColorSecondary"
                    android:visibility="gone"
                    tools:text="4.2 MB"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/send_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/send_subtitle_discovering"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                <!--
                  Weighted middle slot. Hosts the picker scroll AND the
                  status panel layered on top of each other; only one is
                  visible per state. Claiming weight=1 pins the bottom
                  button row to the card's lower edge across every state.
                -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!--
                      Picker container. Vertical stack: a HORIZONTAL row
                      of circular DeviceIconView icons (added at runtime
                      to send_peer_list, wrapped in a HorizontalScrollView)
                      over the empty-state line + same-Wi-Fi hint card.
                      send_peer_scroll keeps its id (View-level toggles
                      only in code) but is now the horizontal device
                      scroller; the empty-state / hint live in a separate
                      column below so the chips scroll independently.
                    -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <HorizontalScrollView
                            android:id="@+id/send_peer_scroll"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fadingEdgeLength="32dp"
                            android:overScrollMode="never"
                            android:requiresFadingEdge="horizontal"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/send_peer_list"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:minWidth="0dp"
                                android:orientation="horizontal" />

                        </HorizontalScrollView>

                        <TextView
                            android:id="@+id/send_empty_state"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:paddingHorizontal="16dp"
                            android:gravity="center"
                            android:text="@string/send_empty_state"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/send_network_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:layout_marginTop="16dp"
                            android:background="?android:attr/colorBackgroundFloating"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/send_network_hint_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/send_network_hint_title"
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/send_network_hint_body"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/send_network_hint_body"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                            <Button
                                android:id="@+id/send_network_hint_dismiss"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:layout_marginTop="8dp"
                                android:text="@string/send_network_hint_dismiss" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/send_status_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/send_status_phase"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Title"
                            tools:text="Awaiting acceptance" />

                        <TextView
                            android:id="@+id/send_status_target"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            tools:text="Sending to Pixel 8" />

                        <FrameLayout
                            android:id="@+id/send_status_circle_wrapper"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:visibility="gone">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/send_status_circle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:indeterminate="false"
                                app:indicatorSize="72dp"
                                app:trackThickness="6dp" />

                            <TextView
                                android:id="@+id/send_status_circle_pct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textStyle="bold"
                                tools:text="42%" />

                        </FrameLayout>

                        <!--
                          send_expert_details — small grey multi-line caption under the
                          progress disc showing transfer speed / ETA / medium when the
                          "expert view" setting is on. Hidden by default; SendActivity /
                          SendActivityInApp toggle visibility + fill the text via
                          renderExpertDetails(). (upstream Bada transfer-expert-view.)
                        -->
                        <TextView
                            android:id="@+id/send_expert_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textColor="?android:attr/textColorSecondary"
                            android:visibility="gone"
                            tools:text="Speed: 12.4 MB/s&#10;ETA: 30 seconds&#10;Medium: Wi-Fi LAN" />

                        <FrameLayout
                            android:id="@+id/send_terminal_preview_card"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/photo_card_background"
                            android:elevation="4dp"
                            android:padding="6dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/send_terminal_preview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/main_send_preview_photo_description"
                                android:scaleType="centerCrop" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/send_pin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:letterSpacing="0.4"
                            android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="1234" />

                        <TextView
                            android:id="@+id/send_status_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            tools:text="Confirm this code matches the receiver's screen." />

                    </LinearLayout>

                </FrameLayout>

                <TextView
                    android:id="@+id/send_rejection_banner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/rejection_banner_background"
                    android:elevation="2dp"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="V2547A 님이 파일 전송을 거절했습니다." />

                <TextView
                    android:id="@+id/send_help_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="@string/send_help_link"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:attr/textColorSecondary" />

                <!-- Cancel / Done as a frosted "glass" plate: a backdrop
                     blur sits behind a transparent-background button. Cancel
                     and Done are mutually exclusive. The id lets SendActivity keep
                     this bottom action row PLANTED during the entrance bounce
                     (DraggableSheetLayout.setBounceBottomAnchors). -->
                <FrameLayout
                    android:id="@+id/send_action_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <dev.bluehouse.bada.ui.BackdropBlurView
                        android:id="@+id/send_cancel_blur"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <Button
                        android:id="@+id/send_cancel_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/btn_frosted_outline_background"
                        android:text="@string/send_cancel" />

                    <Button
                        android:id="@+id/send_done_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/btn_frosted_outline_background"
                        android:text="@string/send_done"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

            <!--
              In-sheet QR panel. Hidden by default; SendActivity toggles
              visibility=VISIBLE and animates a scale + fade transition
              from the card center when the user taps "Show QR". Tapping
              "Done" reverses it back to the picker view.
            -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/send_qr_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/send_qr_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/show_qr_title"
                        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/show_qr_intro"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                    <ImageView
                        android:id="@+id/send_qr_bitmap"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@android:color/white"
                        android:contentDescription="@string/show_qr_image_description" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/qr_url_background"
                        android:fillViewport="true"
                        android:scrollbars="none">

                        <TextView
                            android:id="@+id/send_qr_url"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp"
                            android:singleLine="true"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                            android:textIsSelectable="true" />

                    </HorizontalScrollView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/send_qr_close"
                            style="@style/Widget.Bada.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minWidth="140dp"
                            android:text="@string/show_qr_close"
                            android:textAlignment="center" />

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="wrap_content" />

                        <Button
                            android:id="@+id/send_qr_copy_link"
                            style="@style/Widget.Bada.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minWidth="140dp"
                            android:text="@string/show_qr_copy_link"
                            android:textAlignment="center" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <ImageButton
                android:id="@+id/send_show_qr_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/qr_button_subtle_background"
                android:contentDescription="@string/send_show_qr"
                android:padding="10dp"
                android:src="@drawable/ic_qr_code"
                android:tint="?android:attr/textColorSecondary" />

        </FrameLayout>

        </LinearLayout>

    </dev.bluehouse.bada.ui.sheet.DraggableSheetLayout>

</FrameLayout>
